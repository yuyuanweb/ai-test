APP_DEBUG=true
APP_PORT=9090
SECRET_KEY=your-secret-key-change-in-production

# Session Configuration
SESSION_EXPIRE_SECONDS=2592000
COOKIE_MAX_AGE=2592000

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
