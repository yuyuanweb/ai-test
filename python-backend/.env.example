# 应用配置
APP_NAME=AI评测平台
APP_VERSION=1.0.0
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=9090

# 数据库配置
DATABASE_URL=mysql+aiomysql://root:123456@localhost:3306/ai_eval

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# RabbitMQ 配置（Celery 批量任务，与 Java Spring RabbitMQ 一致）
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# OpenRouter 配置
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Session 配置
SESSION_SECRET_KEY=your-secret-key-here-please-change-in-production
SESSION_MAX_AGE=86400

# CORS 配置
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# 腾讯云 COS（与 Java application.yml 中 tencent.cos 一致）
TENCENT_COS_ACCESS_KEY=
TENCENT_COS_SECRET_KEY=
TENCENT_COS_REGION=ap-guangzhou
TENCENT_COS_BUCKET=yupi-1300582479
# TENCENT_COS_HOST= 可选

# 生产部署（Docker）：由 docker-compose 注入 DB_HOST=mysql、REDIS_HOST=redis、RABBITMQ_HOST=rabbitmq、APP_PORT=8123、APP_DEBUG=false
