# 应用配置
APP_NAME=AI评测平台
APP_VERSION=1.0.0
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=9090

# 数据库配置
DATABASE_URL=mysql+aiomysql://root:123456@localhost:3306/ai_eval

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# OpenRouter配置
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Session配置
SESSION_SECRET_KEY=your-secret-key-here-please-change-in-production
SESSION_MAX_AGE=86400

# CORS配置
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# 腾讯云 COS（与 Java application.yml 中 tencent.cos 一致）
# 对应：tencent.cos.accessKey / secretKey / region / bucket，域名由 bucket+region 自动推导
TENCENT_COS_ACCESS_KEY=
TENCENT_COS_SECRET_KEY=
TENCENT_COS_REGION=ap-guangzhou
TENCENT_COS_BUCKET=yupi-1300582479
# 可选：不填则用 https://<BUCKET>.cos.<REGION>.myqcloud.com
# TENCENT_COS_HOST=
